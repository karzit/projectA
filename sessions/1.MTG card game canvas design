  engine/        # 격리된 순수 규칙 — 서버·클라 공유, Canvas/네트워크 무관
    state, actions, reducer, stack, priority, sba, rng(seeded)
  protocol/      # Action/Message 타입 + 직렬화 스키마(공유)
apps/
  server/        # 권위 엔진 실행 + 가시성 필터(redaction) + 매치메이킹
    rooms, session, redact.ts
  client/        # Canvas 렌더 + 입력 + 예측 + 재화해
    render/, input/, net/, prediction.ts
