attackableTargets(queries.ts:81-89):

for (const lane of ATTACK_LANES[u.cell] ?? []) {
  if (isBackRow && state.field[own][lane]) continue;
  const frontId = state.field[opp][lane];
  if (frontId) {
    add(frontId); // add()가 트랩 유닛은 걸러냄
    continue;      // ← 트랩이라 add 안 됐어도 무조건 continue, 후열 조회 안 함
  }
  for (const backCell of BACK_CELLS_BEHIND[lane] ?? []) add(state.field[opp][backCell]);
}
원인: 제천대성은 턴 시작 시 패악질을 쓰고 스스로 trapped되며, 삼장법사만이 해방 가능합니다. tang-monk가 죽어 없어진 게임에서는 이 트랩이 영구화됩니다. 그런데 frontId가 있으면(트랩 여부 무관) 무조건 continue해서 그 레인의 후열 조회를 건너뛰므로, 트랩된 전열 유닛이 "공격도 못 받고 뒤도 가리는" 상태로 레인을 영구 봉쇄합니다 — 자신도 못 맞고 뒤에 있는 아군/적군도 서로 못 때리는 완전 교착입니다.

이건 방금 넣은 손해거래 게이트가 만든 버그가 아니라(간접적으로 tang-monk 생존율을 높여 이 상황이 더 자주 노출됐을 뿐), CLAUDE.md의 "전열 유닛이 있으면 그 유닛만 대상, 뒤는 가려짐" 룰과 "트랩 유닛은 공격 대상 제외" 룰이 조합될 때 생기는 사각지대입니다. "칸을 물리적으로 점유하고 있으면 트랩 여부와 무관하게 차폐한다"가 의도인지, 아니면 "트랩된(공격 불가) 유닛은 차폐도 안 해야 한다"가 의도인지는 규칙 설계 판단이 필요합니다.

